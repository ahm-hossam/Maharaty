generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum ContentType {
  COURSE
  ARTICLE
  VIDEO
}

enum ActivityType {
  REGISTER
  LOGIN
  VIEW_COURSE
  COMPLETE_COURSE
  START_ASSESSMENT
  COMPLETE_ASSESSMENT
  BUILD_CV
  PRACTICE_INTERVIEW
  VIEW_JOBS
  VIEW_COMMUNITY
  PATH_STEP_COMPLETE
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?  @unique
  password  String
  avatar    String?
  role      Role     @default(USER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userSkills        UserSkill[]
  courseProgresses  CourseProgress[]
  assessmentResults AssessmentResult[]
  notifications     Notification[]
  refreshTokens     RefreshToken[]
  activities        Activity[]
  pushTokens        PushToken[]
  contentProgress   ContentProgress[]
  posts             Post[]
  comments          Comment[]
  reactions         Reaction[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model SkillCategory {
  id     String  @id @default(cuid())
  name   String
  nameAr String
  icon   String?
  skills Skill[]
}

model Skill {
  id          String        @id @default(cuid())
  name        String
  nameAr      String
  description String?
  icon        String?
  isActive    Boolean       @default(true)
  categoryId  String
  category    SkillCategory @relation(fields: [categoryId], references: [id])
  createdAt   DateTime      @default(now())

  userSkills  UserSkill[]
  courses     Course[]
  assessments Assessment[]
}

model UserSkill {
  id       String     @id @default(cuid())
  userId   String
  skillId  String
  level    SkillLevel @default(BEGINNER)
  progress Int        @default(0)
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill    Skill      @relation(fields: [skillId], references: [id])

  @@unique([userId, skillId])
}

model Course {
  id          String     @id @default(cuid())
  title       String
  titleAr     String
  description String?
  thumbnail   String?
  duration    Int
  level       SkillLevel
  skillId     String
  skill       Skill      @relation(fields: [skillId], references: [id])
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())

  progresses CourseProgress[]
}

model CourseProgress {
  id          String    @id @default(cuid())
  userId      String
  courseId    String
  progress    Int       @default(0)
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course    @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
}

model Assessment {
  id           String  @id @default(cuid())
  title        String
  titleAr      String
  skillId      String
  skill        Skill   @relation(fields: [skillId], references: [id])
  duration     Int
  passingScore Int     @default(70)
  isActive     Boolean @default(true)

  questions         Question[]
  assessmentResults AssessmentResult[]
}

model Question {
  id              String     @id @default(cuid())
  text            String
  textAr          String
  assessmentId    String
  assessment      Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  options         Option[]
  correctOptionId String
}

model Option {
  id         String   @id @default(cuid())
  text       String
  textAr     String
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model AssessmentResult {
  id           String     @id @default(cuid())
  userId       String
  assessmentId String
  score        Int
  passed       Boolean
  completedAt  DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessment   Assessment @relation(fields: [assessmentId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String   @default("in-app")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Content {
  id          String      @id @default(cuid())
  type        ContentType
  title       String?
  titleAr     String
  description String?
  thumbnail   String?
  url         String?
  duration    Int?
  category    String?
  meta        Json?
  isPublished Boolean     @default(false)
  createdBy   String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  progresses ContentProgress[]
  activities Activity[]
}

model ContentProgress {
  id          String    @id @default(cuid())
  userId      String
  contentId   String
  progress    Int       @default(0)
  completedAt DateTime?
  lastSeenAt  DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  content     Content   @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([userId, contentId])
}

model Activity {
  id        String       @id @default(cuid())
  userId    String
  type      ActivityType
  meta      Json?
  contentId String?
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Content?     @relation(fields: [contentId], references: [id])
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Post {
  id          String    @id @default(cuid())
  content     String
  image       String?
  authorId    String
  isAdminPost Boolean   @default(false)
  isPinned    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments    Comment[]
  reactions   Reaction[]
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  postId    String
  authorId  String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model Reaction {
  id        String   @id @default(cuid())
  type      String   @default("LIKE")
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}
